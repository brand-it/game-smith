**/config/local.yaml
**/config/*.local.yaml
**/config/production.yaml

# Local Cargo configuration (config.toml for shared settings, config for local overrides)
.cargo/config.local.toml
.cargo/config

# Generated by Cargo
# will have compiled files and executables
debug/
target/

# include cargo lock
!Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

*.sqlite
*.sqlite-*
*.orig
